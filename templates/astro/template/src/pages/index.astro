---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="__PROJECT_NAME__" description="Astro static template starter">
  <section class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
    <div class="rounded-[28px] border border-slate-200/80 bg-white/85 p-8 shadow-[0_24px_80px_-40px_rgba(15,23,42,0.35)] backdrop-blur sm:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Aionsoft Astro Template</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
        Launch __PROJECT_NAME__ with Astro, Tailwind, and shared delivery standards.
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">
        This starter is intended for content-first sites that still need consistent architecture,
        clear operating notes, and an AI-friendly project baseline.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          class="inline-flex items-center justify-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
          href="/"
        >
          Start building
        </a>
        <a
          class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950"
          href="https://docs.astro.build"
        >
          Astro docs
        </a>
      </div>
    </div>

    <aside class="rounded-[28px] border border-slate-200/80 bg-slate-950 p-6 text-slate-50 shadow-[0_24px_80px_-40px_rgba(15,23,42,0.55)]">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-300">Included by default</p>
      <ul class="mt-5 space-y-4 text-sm leading-6 text-slate-300">
        <li><span class="font-semibold text-white">Astro 7</span> for fast static delivery and clean routing.</li>
        <li><span class="font-semibold text-white">Tailwind 4</span> for shared utility-driven UI conventions.</li>
        <li><span class="font-semibold text-white">Specs folder</span> for architecture, content, and delivery guidance.</li>
        <li><span class="font-semibold text-white">AGENTS.md</span> so AI tools follow the same project standards.</li>
      </ul>
    </aside>
  </section>
</MainLayout>
