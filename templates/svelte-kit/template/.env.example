# Enable Swetrix by setting a project id.
PUBLIC_SWETRIX_PROJECT_ID=

# PostgreSQL connection string for Drizzle ORM and postgres-js.
DATABASE_URL=postgresql://postgres:password@localhost:5432/__PROJECT_NAME__

# Optional overrides. Defaults are shown for reference.
PUBLIC_SWETRIX_SCRIPT_URL=https://swetrix.org/swetrix.js
PUBLIC_SWETRIX_API_URL=https://analytics.aionsoft.io/backend/v1/log
PUBLIC_SWETRIX_NOSCRIPT_URL=https://analytics.aionsoft.io/backend/log/noscript
